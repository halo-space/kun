            "selector": ["span.author-born-date"],
            "attribute": "text"
          },
          {
            "name": "born_location",
            "source": "html",
            "selector_type": "css",
            "selector": ["span.author-born-location"],
            "attribute": "text"
          },
          {
            "name": "bio",
            "source": "html",
            "selector_type": "css",
            "selector": ["div.author-description"],
            "attribute": "text"
          }
        ]
